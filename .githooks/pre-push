#!/bin/bash

echo "🧪 Running test suite..."

mvn -q test
TEST_RESULT=$?

if [ $TEST_RESULT -eq 0 ]; then
    echo "✅ Tests passed."
    exit 0
fi

echo ""
echo "❌ Tests failed."

# Lire la branche réellement poussée
while read local_ref local_sha remote_ref remote_sha
do
    BRANCH=$(echo "$local_ref" | sed 's|refs/heads/||')

    if [ "$BRANCH" = "main" ]; then
        echo "🚫 Push to main is blocked."
        exit 1
    fi
done

echo "⚠️ Branch push allowed despite failing tests."
echo "⚠️ CI will likely fail."

exit 0